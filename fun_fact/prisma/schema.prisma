// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Student {
  id          String    @id // Student ID like DR-4824-25
  email       String    @unique
  name        String
  phoneNumber String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Session {
  id        String    @id @default(uuid())
  day       Day
  timeSlot  TimeSlot
  capacity  Int       @default(4)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  metadata  Json?

  @@unique([day, timeSlot])
}

enum BookingStatus {
  BOOKED
  ATTENDED
  NO_SHOW
  COMPLETED
  INCOMPLETE
  CANCELLED
}

model Booking {
  id            String        @id @default(uuid())
  student       Student       @relation(fields: [studentId], references: [id])
  studentId     String
  session       Session       @relation(fields: [sessionId], references: [id])
  sessionId     String
  status        BookingStatus @default(BOOKED)
  weekOf        DateTime      @default(now()) // Monday of the booking week
  markedBy      User?         @relation("BookingsMarked", fields: [markedById], references: [id])
  markedById    String?
  attendedAt    DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  statusHistory BookingStatusHistory[]

  @@unique([studentId, sessionId, weekOf])
  @@index([studentId])
  @@index([weekOf])
  @@index([status])
}

model BookingStatusHistory {
  id          String         @id @default(uuid())
  booking     Booking        @relation(fields: [bookingId], references: [id])
  bookingId   String
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  changedBy   User?          @relation("StatusChanges", fields: [changedById], references: [id])
  changedById String?
  reason      String?
  createdAt   DateTime       @default(now())

  @@index([bookingId])
}

enum Role {
  INSTRUCTOR
  ADMIN
}

model User {
  id             String                 @id @default(uuid())
  email          String                 @unique
  name           String
  password       String                 // bcrypt hash
  role           Role                   @default(INSTRUCTOR)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  bookingsMarked Booking[]              @relation("BookingsMarked")
  statusChanges  BookingStatusHistory[] @relation("StatusChanges")
}

model SystemSetting {
  key       String   @id
  value     String
  label     String
  type      String   @default("number")
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(uuid())
  action    String
  message   String
  data      Json?
  createdAt DateTime @default(now())
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum TimeSlot {
  SLOT_8_10 // Monday-Friday: 8-10am
  SLOT_10_12 // Monday-Friday: 10am-12pm
  SLOT_13_15 // Monday-Friday: 1-3pm
  SLOT_15_17 // Monday-Friday: 3-5pm
  SLOT_9_11 // Weekend: 9-11am
  SLOT_11_13 // Weekend: 11am-1pm
  SLOT_14_16 // Weekend: 2-4pm
  SLOT_16_18 // Weekend: 4-6pm
}
